{
  "entities": {
    "influencer": {
      "title": "Influencer",
      "description": "A local influencer or content creator.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "category": { "type": "string" },
        "followers": { "type": "string" },
        "bio": { "type": "string" },
        "imageUrl": { "type": "string" },
        "socialLinks": { "type": "object" },
        "videos": { 
          "type": "array", 
          "items": { 
            "type": "object",
            "properties": {
              "title": { "type": "string" },
              "url": { "type": "string" }
            }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" },
        "uid": { "type": "string" }
      },
      "required": ["name", "category", "bio", "uid"]
    },
    "product": {
      "title": "Product",
      "description": "A product sold by a shop.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "price": { "type": "number" },
        "description": { "type": "string" },
        "imageUrl": { "type": "string" },
        "category": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "price", "imageUrl"]
    },
    "order": {
      "title": "Order",
      "description": "An order placed by a customer.",
      "type": "object",
      "properties": {
        "shopId": { "type": "string" },
        "shopName": { "type": "string" },
        "customerName": { "type": "string" },
        "customerPhone": { "type": "string" },
        "customerLocation": { 
          "type": "object",
          "properties": {
            "lat": { "type": "number" },
            "lng": { "type": "number" },
            "address": { "type": "string" }
          }
        },
        "items": { 
          "type": "array", 
          "items": { 
            "type": "object",
            "properties": {
              "productId": { "type": "string" },
              "name": { "type": "string" },
              "price": { "type": "number" },
              "quantity": { "type": "integer" }
            }
          }
        },
        "totalPrice": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "verified", "completed", "cancelled"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["shopId", "customerName", "customerPhone", "items", "totalPrice", "status"]
    },
    "shop": {
      "title": "Shop",
      "description": "A local shop or business in Barnia Bazar.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "category": { "type": "string" },
        "location": { "type": "string" },
        "description": { "type": "string" },
        "imageUrl": { "type": "string" },
        "contact": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "uid": { "type": "string" }
      },
      "required": ["name", "category", "description", "uid"]
    },
    "user": {
      "title": "User",
      "description": "A user of the application.",
      "type": "object",
      "properties": {
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "user"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "role"]
    },
    "message": {
      "title": "Message",
      "description": "A message in the collaboration tools.",
      "type": "object",
      "properties": {
        "text": { "type": "string" },
        "senderId": { "type": "string" },
        "senderName": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["text", "senderId", "senderName"]
    },
    "support_message": {
      "title": "Support Message",
      "description": "A message in the live support chat.",
      "type": "object",
      "properties": {
        "text": { "type": "string" },
        "sessionId": { "type": "string" },
        "isBot": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["text", "sessionId"]
    },
    "stat": {
      "title": "Statistic",
      "description": "A global statistic for the application.",
      "type": "object",
      "properties": {
        "count": { "type": "integer" }
      },
      "required": ["count"]
    },
    "collab_request": {
      "title": "Collaboration Request",
      "description": "A request for collaboration sent to an influencer.",
      "type": "object",
      "properties": {
        "fromName": { "type": "string" },
        "toInfluencerId": { "type": "string" },
        "toInfluencerName": { "type": "string" },
        "message": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "toUid": { "type": "string" },
        "fromUid": { "type": "string" }
      },
      "required": ["fromName", "toInfluencerId", "toInfluencerName", "message"]
    },
    "news": {
      "title": "News",
      "description": "Daily news articles generated by AI.",
      "type": "object",
      "properties": {
        "date": { "type": "string", "format": "date" },
        "lang": { "type": "string", "description": "Language code (e.g., 'en', 'bn')" },
        "local": { "type": "array", "items": { "$ref": "news_item" } },
        "fbTrends": { "type": "array", "items": { "$ref": "news_item" } },
        "igTrends": { "type": "array", "items": { "$ref": "news_item" } },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["date", "lang", "local", "fbTrends", "igTrends", "updatedAt"]
    },
    "news_item": {
      "title": "News Item",
      "description": "A single news article.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "content": { "type": "string" },
        "source": { "type": "string" },
        "date": { "type": "string" }
      },
      "required": ["title", "content", "source", "date"]
    },
    "visitor_session": {
      "title": "Visitor Session",
      "description": "A single visitor session tracking location and duration.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "startTime": { "type": "string", "format": "date-time" },
        "lastSeen": { "type": "string", "format": "date-time" },
        "country": { "type": "string" },
        "city": { "type": "string" },
        "ip": { "type": "string" },
        "userAgent": { "type": "string" },
        "referrer": { "type": "string" },
        "events": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["id", "startTime", "lastSeen"]
    },
    "inbound_email": {
      "title": "Inbound Email",
      "description": "An email received via webhook for domain verification.",
      "type": "object",
      "properties": {
        "from": { "type": "string" },
        "to": { "type": "string" },
        "subject": { "type": "string" },
        "body": { "type": "string" },
        "html": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["from", "to", "subject", "body", "timestamp"]
    }
  },
  "firestore": {
    "/influencers/{influencerId}": {
      "schema": "influencer",
      "description": "Collection of local influencers."
    },
    "/shops/{shopId}": {
      "schema": "shop",
      "description": "Collection of local shops in Barnia Bazar."
    },
    "/shops/{shopId}/products/{productId}": {
      "schema": "product",
      "description": "Products sold by a specific shop."
    },
    "/orders/{orderId}": {
      "schema": "order",
      "description": "Orders placed by customers."
    },
    "/users/{userId}": {
      "schema": "user",
      "description": "User profiles and roles."
    },
    "/messages/{messageId}": {
      "schema": "message",
      "description": "Collaboration messages."
    },
    "/support_messages/{messageId}": {
      "schema": "support_message",
      "description": "Support chat messages."
    },
    "/stats/{statId}": {
      "schema": "stat",
      "description": "Global application statistics like visitor counts."
    },
    "/collab_requests/{requestId}": {
      "schema": "collab_request",
      "description": "Collaboration requests sent to influencers."
    },
    "/news/{newsId}": {
      "schema": "news",
      "description": "Daily news articles."
    },
    "/visitor_sessions/{sessionId}": {
      "schema": "visitor_session",
      "description": "Tracking of visitor sessions for analytics."
    },
    "/inbound_emails/{emailId}": {
      "schema": "inbound_email",
      "description": "Emails received for domain verification."
    }
  }
}
