{
  "entities": {
    "VamshavaliProfile": {
      "title": "Vamshavali Profile",
      "description": "A family lineage profile",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "shareId": { "type": "string" },
        "members": { "type": "array" },
        "kuldevi": { "type": "string" },
        "kuldevta": { "type": "string" },
        "gotra": { "type": "string" },
        "nativePlace": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "TelegramLink": {
      "title": "Telegram Link",
      "description": "Connection between Telegram Chat ID and Profile ID",
      "type": "object",
      "properties": {
        "profileId": { "type": "string" },
        "profileName": { "type": "string" },
        "linkedAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "firestore": {
    "vamshavali_profiles/{profileId}": {
      "schema": "VamshavaliProfile",
      "description": "Collection of family trees"
    },
    "telegram_links/{chatId}": {
      "schema": "TelegramLink",
      "description": "Mapping from Telegram chat IDs to profile IDs"
    }
  }
}
