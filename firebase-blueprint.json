{
  "entities": {
    "influencer": {
      "title": "Influencer",
      "description": "A local influencer or content creator.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "category": { "type": "string" },
        "followers": { "type": "string" },
        "bio": { "type": "string" },
        "imageUrl": { "type": "string" },
        "socialLinks": { "type": "object" },
        "videos": { 
          "type": "array", 
          "items": { 
            "type": "object",
            "properties": {
              "title": { "type": "string" },
              "url": { "type": "string" }
            }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" },
        "uid": { "type": "string" }
      },
      "required": ["name", "category", "bio", "uid"]
    },
    "product": {
      "title": "Product",
      "description": "A product sold by a shop.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "price": { "type": "number" },
        "description": { "type": "string" },
        "imageUrl": { "type": "string" },
        "category": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "price", "imageUrl"]
    },
    "order": {
      "title": "Order",
      "description": "An order placed by a customer.",
      "type": "object",
      "properties": {
        "shopId": { "type": "string" },
        "shopName": { "type": "string" },
        "customerName": { "type": "string" },
        "customerPhone": { "type": "string" },
        "customerLocation": { 
          "type": "object",
          "properties": {
            "lat": { "type": "number" },
            "lng": { "type": "number" },
            "address": { "type": "string" }
          }
        },
        "items": { 
          "type": "array", 
          "items": { 
            "type": "object",
            "properties": {
              "productId": { "type": "string" },
              "name": { "type": "string" },
              "price": { "type": "number" },
              "quantity": { "type": "integer" }
            }
          }
        },
        "totalPrice": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "verified", "completed", "cancelled"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["shopId", "customerName", "customerPhone", "items", "totalPrice", "status"]
    },
    "shop": {
      "title": "Shop",
      "description": "A local shop or business in Barnia Bazar.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "category": { "type": "string" },
        "location": { "type": "string" },
        "description": { "type": "string" },
        "imageUrl": { "type": "string" },
        "contact": { "type": "string" },
        "todayOffer": { "type": "string", "description": "Current special offer or discount." },
        "createdAt": { "type": "string", "format": "date-time" },
        "uid": { "type": "string" }
      },
      "required": ["name", "category", "description", "uid"]
    },
    "market_rate": {
      "title": "Market Rate",
      "description": "Daily market rate for a specific item.",
      "type": "object",
      "properties": {
        "itemName": { "type": "string" },
        "price": { "type": "string" },
        "trend": { "type": "string", "enum": ["up", "down", "stable"] },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["itemName", "price", "trend", "updatedAt"]
    },
    "fact_check_submission": {
      "title": "Fact Check Submission",
      "description": "A claim submitted by a user for fact-checking.",
      "type": "object",
      "properties": {
        "claim": { "type": "string" },
        "evidence": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "reviewing", "checked"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "userEmail": { "type": "string" },
        "userUid": { "type": "string" }
      },
      "required": ["claim", "status", "createdAt"]
    },
    "fact_check": {
      "title": "Fact Check",
      "description": "A verified fact-check item.",
      "type": "object",
      "properties": {
        "claim": { "type": "string" },
        "status": { "type": "string", "enum": ["verified", "false", "misleading"] },
        "explanation": { "type": "string" },
        "source": { "type": "string" },
        "category": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["claim", "status", "explanation", "date"]
    },
    "user": {
      "title": "User",
      "description": "A user of the application.",
      "type": "object",
      "properties": {
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "user"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "role"]
    },
    "message": {
      "title": "Message",
      "description": "A message in the collaboration tools.",
      "type": "object",
      "properties": {
        "text": { "type": "string" },
        "senderId": { "type": "string" },
        "senderName": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["text", "senderId", "senderName"]
    },
    "support_message": {
      "title": "Support Message",
      "description": "A message in the live support chat.",
      "type": "object",
      "properties": {
        "text": { "type": "string" },
        "sessionId": { "type": "string" },
        "isBot": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["text", "sessionId"]
    },
    "stat": {
      "title": "Statistic",
      "description": "A global statistic for the application.",
      "type": "object",
      "properties": {
        "count": { "type": "integer" }
      },
      "required": ["count"]
    },
    "collab_request": {
      "title": "Collaboration Request",
      "description": "A request for collaboration sent to an influencer.",
      "type": "object",
      "properties": {
        "fromName": { "type": "string" },
        "toInfluencerId": { "type": "string" },
        "toInfluencerName": { "type": "string" },
        "message": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "toUid": { "type": "string" },
        "fromUid": { "type": "string" }
      },
      "required": ["fromName", "toInfluencerId", "toInfluencerName", "message"]
    },
    "news": {
      "title": "News",
      "description": "Daily news articles generated by AI.",
      "type": "object",
      "properties": {
        "date": { "type": "string", "format": "date" },
        "lang": { "type": "string", "description": "Language code (e.g., 'en', 'bn')" },
        "local": { "type": "array", "items": { "$ref": "news_item" } },
        "fbTrends": { "type": "array", "items": { "$ref": "news_item" } },
        "igTrends": { "type": "array", "items": { "$ref": "news_item" } },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["date", "lang", "local", "fbTrends", "igTrends", "updatedAt"]
    },
    "news_item": {
      "title": "News Item",
      "description": "A single news article.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "content": { "type": "string" },
        "source": { "type": "string" },
        "date": { "type": "string" }
      },
      "required": ["title", "content", "source", "date"]
    },
    "visitor_session": {
      "title": "Visitor Session",
      "description": "A single visitor session tracking location and duration.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "startTime": { "type": "string", "format": "date-time" },
        "lastSeen": { "type": "string", "format": "date-time" },
        "country": { "type": "string" },
        "city": { "type": "string" },
        "ip": { "type": "string" },
        "userAgent": { "type": "string" },
        "referrer": { "type": "string" },
        "events": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["id", "startTime", "lastSeen"]
    },
    "inbound_email": {
      "title": "Inbound Email",
      "description": "An email received via webhook for domain verification.",
      "type": "object",
      "properties": {
        "from": { "type": "string" },
        "to": { "type": "string" },
        "subject": { "type": "string" },
        "body": { "type": "string" },
        "html": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["from", "to", "subject", "body", "timestamp"]
    },
    "vehicle": {
      "title": "Vehicle",
      "description": "A vehicle registered for the village transport service.",
      "type": "object",
      "properties": {
        "driverUid": { "type": "string" },
        "driverName": { "type": "string" },
        "driverPhone": { "type": "string" },
        "vehicleType": { "type": "string", "enum": ["Toto", "Auto", "Van", "Bike", "Car"] },
        "vehicleNumber": { "type": "string" },
        "status": { "type": "string", "enum": ["available", "busy", "offline"] },
        "location": {
          "type": "object",
          "properties": {
            "lat": { "type": "number" },
            "lng": { "type": "number" },
            "address": { "type": "string" }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["driverUid", "driverName", "driverPhone", "vehicleType", "status"]
    },
    "ride_request": {
      "title": "Ride Request",
      "description": "A request for a ride sent by a user.",
      "type": "object",
      "properties": {
        "riderUid": { "type": "string" },
        "riderName": { "type": "string" },
        "riderPhone": { "type": "string" },
        "from": { "type": "string" },
        "to": { "type": "string" },
        "vehicleId": { "type": "string" },
        "driverUid": { "type": "string" },
        "driverName": { "type": "string" },
        "driverPhone": { "type": "string" },
        "fare": { "type": "number" },
        "rating": { "type": "integer", "minimum": 1, "maximum": 5 },
        "status": { "type": "string", "enum": ["pending", "accepted", "completed", "cancelled"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["riderUid", "riderName", "riderPhone", "from", "to", "status"]
    },
    "ride_chat_message": {
      "title": "Ride Chat Message",
      "description": "A message sent between a rider and a driver for a specific ride.",
      "type": "object",
      "properties": {
        "requestId": { "type": "string" },
        "senderUid": { "type": "string" },
        "senderName": { "type": "string" },
        "text": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["requestId", "senderUid", "senderName", "text"]
    },
    "ride_call": {
      "title": "Ride Call",
      "description": "A WebRTC signaling session for a voice call between rider and driver.",
      "type": "object",
      "properties": {
        "requestId": { "type": "string" },
        "callerUid": { "type": "string" },
        "receiverUid": { "type": "string" },
        "offer": { "type": "object" },
        "answer": { "type": "object" },
        "iceCandidates": { "type": "array", "items": { "type": "object" } },
        "status": { "type": "string", "enum": ["calling", "ongoing", "ended", "missed"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["requestId", "callerUid", "receiverUid", "status"]
    },
    "vamshavali_otp": {
      "title": "Vamshavali OTP",
      "description": "Temporary OTP for Vamshavali dashboard login.",
      "type": "object",
      "properties": {
        "otp": { "type": "string" },
        "expiresAt": { "type": "string", "format": "date-time" }
      },
      "required": ["otp", "expiresAt"]
    },
    "vamshavali_profile": {
      "title": "Vamshavali Profile",
      "description": "A user's family tree profile.",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "shareId": { "type": "string" },
        "name": { "type": "string" },
        "parents": { "type": "string" },
        "grandparents": { "type": "string" },
        "gotra": { "type": "string" },
        "kuldevi": { "type": "string" },
        "kuldevta": { "type": "string" },
        "nativePlace": { "type": "string" },
        "additionalNotes": { "type": "string" },
        "members": { "type": "array", "items": { "type": "object" } },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "shareId"]
    }
  },
  "firestore": {
    "/influencers/{influencerId}": {
      "schema": "influencer",
      "description": "Collection of local influencers."
    },
    "/shops/{shopId}": {
      "schema": "shop",
      "description": "Collection of local shops in Barnia Bazar."
    },
    "/shops/{shopId}/products/{productId}": {
      "schema": "product",
      "description": "Products sold by a specific shop."
    },
    "/orders/{orderId}": {
      "schema": "order",
      "description": "Orders placed by customers."
    },
    "/users/{userId}": {
      "schema": "user",
      "description": "User profiles and roles."
    },
    "/messages/{messageId}": {
      "schema": "message",
      "description": "Collaboration messages."
    },
    "/support_messages/{messageId}": {
      "schema": "support_message",
      "description": "Support chat messages."
    },
    "/stats/{statId}": {
      "schema": "stat",
      "description": "Global application statistics like visitor counts."
    },
    "/collab_requests/{requestId}": {
      "schema": "collab_request",
      "description": "Collaboration requests sent to influencers."
    },
    "/news/{newsId}": {
      "schema": "news",
      "description": "Daily news articles."
    },
    "/visitor_sessions/{sessionId}": {
      "schema": "visitor_session",
      "description": "Tracking of visitor sessions for analytics."
    },
    "/inbound_emails/{emailId}": {
      "schema": "inbound_email",
      "description": "Emails received for domain verification."
    },
    "/vehicles/{vehicleId}": {
      "schema": "vehicle",
      "description": "Collection of registered vehicles."
    },
    "/ride_requests/{requestId}": {
      "schema": "ride_request",
      "description": "Requests for rides."
    },
    "/ride_chat_messages/{messageId}": {
      "schema": "ride_chat_message",
      "description": "Messages sent between a rider and a driver for a specific ride."
    },
    "/market_rates/{rateId}": {
      "schema": "market_rate",
      "description": "Daily market rates for items in Barnia Bazar."
    },
    "/fact_check_submissions/{submissionId}": {
      "schema": "fact_check_submission",
      "description": "User submitted claims for fact-checking."
    },
    "/fact_checks/{factId}": {
      "schema": "fact_check",
      "description": "Verified fact checks."
    },
    "/vamshavali_otps/{email}": {
      "schema": "vamshavali_otp",
      "description": "OTP storage for Vamshavali login."
    },
    "/vamshavali_profiles/{profileId}": {
      "schema": "vamshavali_profile",
      "description": "User family tree profiles."
    }
  }
}
