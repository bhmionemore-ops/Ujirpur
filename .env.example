# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# EMAIL_USER: The email address used to send notifications (e.g., Gmail)
EMAIL_USER="your-email@gmail.com"
# EMAIL_PASS: The app password for the email service
EMAIL_PASS="your-app-password"
# NOTIFICATION_EMAIL: The recipient for all notifications
NOTIFICATION_EMAIL="ujirpur.barnia6@gmail.com"

# APP_URL: The base URL of the application for social sharing meta tags
# Example: https://your-app-name.run.app
# The base URL of the application. Set this to your custom domain (e.g., https://barnia.in)
# if you have one, otherwise it will default to the current host.
APP_URL="https://barnia.in"

# Meta for Developers: Facebook Login Configuration
# Register your app at https://developers.facebook.com
FACEBOOK_CLIENT_ID="2201629183577400"
FACEBOOK_CLIENT_SECRET="3494ad98c498cda892b65006cf833273"
