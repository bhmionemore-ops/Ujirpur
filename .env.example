# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# EMAIL_USER: The email address used to send notifications (Gmail)
# Recommended: ujirpur.barnia6@gmail.com
EMAIL_USER="ujirpur.barnia6@gmail.com"
# EMAIL_PASS: The app password for the email service
EMAIL_PASS="your-app-password"
# NOTIFICATION_EMAIL: The recipient for all notifications
NOTIFICATION_EMAIL="info@barnia.in"

# HTTP API Email fallbacks (Highly Recommended for Render.com Free tier)
# Since Render Free tier entirely blocks outbound direct TCP mail ports (587, 465, 25),
# providing one of these transactional email API keys allows sending emails over 
# standard HTTP/Port 443 seamlessly without any firewall blocks.
RESEND_API_KEY=""
BREVO_API_KEY=""
SENDGRID_API_KEY=""

# APP_URL: The base URL of the application for social sharing meta tags
# Example: https://your-app-name.run.app
# The base URL of the application. Set this to your custom domain (e.g., https://barnia.in)
# if you have one, otherwise it will default to the current host.
APP_URL="https://barnia.in"

# AI Router SaaS Configuration
OPENROUTER_API_KEY=
DASHSCOPE_API_KEY=
FLUX_API_KEY=
MINIMAX_API_KEY=
MINIMAX_GROUP_ID=
VIDEO_API_KEY=
AI_ROUTER_ADMIN_PASSWORD=

# Professional Credentials (Optional, for Admin SDK bypass)
FIREBASE_SERVICE_ACCOUNT=
GOOGLE_APPLICATION_CREDENTIALS=

# Meta for Developers: Facebook Login Configuration
# Register your app at https://developers.facebook.com
FACEBOOK_CLIENT_ID="2201629183577400"
FACEBOOK_CLIENT_SECRET="3494ad98c498cda892b65006cf833273"

# Telegram Bot configuration for family tree updates
TELEGRAM_BOT_TOKEN=
VITE_TELEGRAM_BOT_USERNAME=
ADMIN_TELEGRAM_CHAT_ID=

# WhatsApp Integration (Meta Cloud API - 1,000 free convos/mo)
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=
